# Server configuration
PORT=8000
HOST=0.0.0.0

# Database
DATABASE_URL=sqlite+aiosqlite:///ken_db.sqlite


# Auth JWT Secret
JWT_SECRET=super_secret_jwt_key_please_change_in_production
